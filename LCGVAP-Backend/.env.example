# ============================================================
# LCGVAP Backend — Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ⚠️  NEVER commit the actual .env file to version control!
# ============================================================

# Server
NODE_ENV=development
PORT=5000
BASE_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── PostgreSQL Database ──────────────────────────────────────
# Prefer DATABASE_URL in production (Render/Supabase/Neon).
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lcgvap_db
DB_USER=postgres
DB_PASSWORD=YOUR_STRONG_DB_PASSWORD_HERE

# Optional DB pool tuning
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_CONNECT_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
DB_STATEMENT_TIMEOUT_MS=7000
DB_QUERY_TIMEOUT_MS=7000

# ── JWT Secrets ──────────────────────────────────────────────
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=GENERATE_A_64_BYTE_HEX_STRING
JWT_REFRESH_SECRET=GENERATE_A_DIFFERENT_64_BYTE_HEX_STRING
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Admin Creation Secret ────────────────────────────────────
# Required as X-Admin-Secret header to create the first boss admin.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_CREATION_SECRET=GENERATE_A_32_BYTE_HEX_STRING

# ── Email (Gmail App Password) ───────────────────────────────
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── Redis (local dev, Railway, or Upstash) ───────────────────
# Local (no password):     REDIS_URL=redis://localhost:6379
# Local (docker compose):    REDIS_URL=redis://:redis_secure_pass@localhost:6379
# Railway: reference Redis service → REDIS_URL (not localhost)
REDIS_URL=redis://localhost:6379

# ── Security / Auth Limits ───────────────────────────────────
AUTH_RATE_LIMIT_MAX=10
BOSS_ADMIN_MAX=3
MAX_UPLOAD_SIZE_MB=15
FILE_ACCESS_SECRET=
