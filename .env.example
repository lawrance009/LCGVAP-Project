# =============================================================================
# LCGVAP - Liberian Cyprus Graduates Veteran Alumina Platform
# Environment Configuration Template
# =============================================================================
# WARNING: Never commit this file with real values to version control!
# Copy this file to .env and fill in your actual values.
# =============================================================================

# -----------------------------------------------------------------------------
# System Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
SYSTEM_NAME=LCGVAP
SYSTEM_FULL_NAME=Liberian Cyprus Graduates Veteran Alumina Platform

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_USER=lcgvap
DB_PASSWORD=your_secure_database_password_here
DB_NAME=lcgvap_db
DB_PORT=5432
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:${DB_PORT}/${DB_NAME}?schema=public

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# JWT Authentication Secrets (Generate strong random strings)
# -----------------------------------------------------------------------------
# Use: openssl rand -base64 64
JWT_ACCESS_SECRET=your_jwt_access_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Default Master Admin Credentials (Only used for initial setup)
# -----------------------------------------------------------------------------
ADMIN_DEFAULT_EMAIL=admin@lcgvap.gov.lr
ADMIN_DEFAULT_PASSWORD=your_secure_admin_password_here

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# API & Frontend Ports
# -----------------------------------------------------------------------------
API_PORT=3001
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Email Configuration (Optional - for notifications)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@lcgvap.gov.lr
